APP_NAME="MultiLot 360 API"
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
LOG_LEVEL=log

SWAGGER_ENABLED=true
SWAGGER_PATH=docs

SUPABASE_PROJECT_REF=wweiogaeaikasrlldbdy
SUPABASE_URL=https://wweiogaeaikasrlldbdy.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# Prisma CLI uses PRISMA_DATABASE_URL first. Prefer the exact Direct connection
# from Supabase Connect for db pull/migrations, or the exact Session Pooler URL
# copied from the dashboard if your network cannot reach IPv6 direct host.
PRISMA_DATABASE_URL="postgresql://postgres:<url-encoded-password>@db.wweiogaeaikasrlldbdy.supabase.co:5432/postgres?sslmode=require&schema=public"
DATABASE_URL="postgresql://postgres.wweiogaeaikasrlldbdy:<url-encoded-password>@<exact-session-pooler-host-from-supabase>:5432/postgres?sslmode=require&schema=public"
DIRECT_URL="postgresql://postgres:<url-encoded-password>@db.wweiogaeaikasrlldbdy.supabase.co:5432/postgres?sslmode=require&schema=public"
DB_HOST=db.wweiogaeaikasrlldbdy.supabase.co
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=<raw-password>
DB_DATABASE=postgres
DB_SSL=true

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=multilot_redis_dev
REDIS_DB=0
REDIS_KEY_PREFIX=multilot360:development:
REDIS_INSIGHT_PORT=8001

MAILERSEND_SMTP_HOST=smtp.mailersend.net
MAILERSEND_SMTP_PORT=587
MAILERSEND_SMTP_USER=
MAILERSEND_SMTP_PASSWORD=
MAILERSEND_FROM_EMAIL=no-reply@your-verified-domain.com
MAILERSEND_FROM_NAME="MultiLot 360"

LOCAL_DB_USERNAME=postgres
LOCAL_DB_PASSWORD=postgres
LOCAL_DB_DATABASE=multilot360
LOCAL_DB_PORT=54329
